# Server Configuration
PORT_NUMBER=4000

# MongoDB Configuration
MONGO_URI_BASE=mongodb+srv://username:password@cluster.mongodb.net/
COLLECTION_NAME=your_database_name
MONGO_URI_SUFFIX=?retryWrites=true&w=majority

# JWT Secrets (Generate secure random strings for production)
JWT_SECRET=your-super-secret-jwt-key-change-this
CONTAINER_JWT_SECRET=your-container-jwt-secret-change-this
TENANT_JWT_SECRET=your-tenant-jwt-secret-change-this

# Cloudinary Configuration (for image uploads)
CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:4000/auth/google/callback

# Application URLs
BACKEND_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Environment (development, production)
NODE_ENV=development
