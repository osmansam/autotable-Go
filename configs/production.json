{
  "redis": {
    "port": "6379",
    "host": "redis",
    "password": "",
    "pool": {
      "poolSize": 50,
      "minIdleConnections": 10,
      "poolTimeoutSeconds": 4,
      "idleTimeoutSeconds": 300,
      "idleCheckFrequencySeconds": 60,
      "maxConnectionAgeSeconds": 0
    },
    "circuitBreaker": {
      "enabled": true,
      "failureThreshold": 3,
      "openDurationSeconds": 30
    }
  },
  "mongo": {
    "pool": {
      "minPoolSize": 5,
      "maxPoolSize": 100,
      "maxConnectionIdleSeconds": 300,
      "connectTimeoutSeconds": 10
    }
  },
  "app": {
    "port": 4000
  },
  "panel": {
    "host": "http://localhost:3000"
  },
  "cache": {
    "defaultCacheTTLMinutes": 10,
    "cacheFillLockTTLSeconds": 15,
    "cacheFillWaitTimeoutMilliseconds": 800,
    "cacheFillPollIntervalMilliseconds": 50
  },
  "limits": {
    "defaultPageLimit": 20,
    "maxPageLimit": 100,
    "maxUnboundedReadLimit": 5000,
    "maxExportLimit": 50000,
    "maxBulkWriteLimit": 1000,
    "maxBulkUpdateLimit": 1000,
    "maxBulkDeleteLimit": 1000,
    "bodySizeLimits": {
      "defaultBodySizeBytes": 1048576,
      "bulkWriteBodySizeBytes": 10485760,
      "bulkUpdateBodySizeBytes": 10485760,
      "bulkDeleteBodySizeBytes": 2097152,
      "exportBodySizeBytes": 1048576,
      "uploadBodySizeBytes": 26214400
    }
  },
  "corsWhitelist": ["https://tenant.autoapi.org", "https://panel.autoapi.org"],
  "migrationEnabled": false
}
